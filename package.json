{
  "name": "multiplayer-quiz",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @quiz/api --filter @quiz/web dev",
    "start": "pnpm --filter @quiz/api start",
    "build:api": "pnpm --filter @quiz/shared build && pnpm --filter @quiz/game-core build && pnpm --filter @quiz/api prisma:generate && pnpm --filter @quiz/api build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @quiz/api prisma:generate",
    "db:migrate": "pnpm --filter @quiz/api prisma:migrate",
    "db:deploy": "pnpm --filter @quiz/api prisma:deploy"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
